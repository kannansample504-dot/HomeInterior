# ============================================
# Home Interior — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_DB=homeinterior
POSTGRES_USER=homeinterior
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Django ----------
DJANGO_SECRET_KEY=changeme-django-secret-key-at-least-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ---------- JWT (shared by Django + NestJS) ----------
JWT_SECRET=changeme-jwt-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret-key-at-least-32-chars
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ---------- NestJS ----------
NEST_PORT=3001

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost
